# ═══════════════════════════════════════════════════════
# gIVEMEGAME.IO — Server Configuration
# ═══════════════════════════════════════════════════════
# 1. Skopíruj tento súbor: copy .env.example .env
# 2. Do .env vlož svoj skutočný OPENAI_API_KEY
# 3. .env.example = šablóna (placeholder), .env = tvoje hodnoty
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════

# ─── OpenAI API ───────────────────────────────────────
# Your OpenAI API key (starts with sk-)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Model to use for game generation + narrator (text)
# gpt-5.4 = best quality (recommended)
# gpt-4o = alternative
OPENAI_MODEL=gpt-5.4

# TTS model (hlas vypraváča) — oddelený od chat modelu
# gpt-4o-mini-tts = najnovší, GPT-5.4 nemá vlastný hlasový model
OPENAI_TTS_MODEL=gpt-4o-mini-tts

# Štýl SMARTA — genz = Gen Z slang (obsah rovnaký, len iný slovník)
# NARRATOR_STYLE=genz

# Max tokens for generation response
OPENAI_MAX_TOKENS=5000

# Temperature (0.0 = deterministic, 1.0 = creative)
OPENAI_TEMPERATURE=0.8

# ─── Supabase (pre migrácie) ───────────────────────────
# Z Supabase Dashboard → Project Settings → Database → Connection string (URI)
# Session mode, napr: postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=your-supabase-connection-string-here

# ─── Server ───────────────────────────────────────────
# Port for the backend API server
PORT=3000

# Environment: development | production
NODE_ENV=development
